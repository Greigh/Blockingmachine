# Apple notarization credentials (recommended env var names)
APPLE_ID=me@danielhipskind.com
APPLE_PASSWORD=your-apple-id-password
APPLE_TEAM_ID=-your-apple-team-id

# GitHub / NPM tokens for publishing & CI
GH_TOKEN=your-github-token
NPM_TOKEN=your-npm-token
GH_USERNAME=your-github-username

# Notes:
# - Do NOT commit a real .env to the repository. Use CI secrets or local environment variables instead.
# - Older setups used APPLE_ID_PASSWORD; the code accepts that as a fallback for compatibility.
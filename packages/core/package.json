{
  "name": "@blockingmachine/core",
  "version": "1.0.0-beta.8",
  "type": "module",
  "author": {
    "name": "Daniel Hipskind",
    "email": "me@danielhipskind.com",
    "url": "https://danielhipskind.com"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "license": "BSD-3-Clause",
  "scripts": {
    "build": "tsc --skipLibCheck",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "publish": "node ../../scripts/publish-npm.js core"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "adguard",
    "filtering",
    "blocking"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greigh/Blockingmachine-core.git"
  },
  "bugs": {
    "url": "https://github.com/greigh/Blockingmachine-core/issues"
  },
  "homepage": "https://github.com/greigh/Blockingmachine-core#readme",
  "dependencies": {
    "@adguard/aglint": "^3.0.2",
    "chalk": "^5.6.2",
    "debug": "^4.4.3",
    "node-fetch": "^3.3.2",
    "only": "^0.0.2",
    "progress": "^2.0.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/progress": "^2.0.7",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "npm": ">=11.3.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "scope": "@blockingmachine"
  }
}
